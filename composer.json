{
    "name": "mivodev/laravel-mikrotik-api-ros6",
    "description": "Laravel Wrapper for Mivo Enterprise Mikrotik API RouterOS v6",
    "type": "library",
    "require": {
        "php": "^8.2 | ^8.3",
        "mivodev/mikrotik-api-ros6": "*@dev",
        "illuminate/support": "^10.0 | ^11.0 | ^12.0 | ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Mivo\\LaravelMikrotikRos6\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mivo\\LaravelMikrotikRos6\\MikrotikRos6ServiceProvider"
            ]
        }
    }
}
