{
    "name": "mivodev/laravel-mikrotik-api-ros6",
    "description": "Laravel wrapper for mivodev/mikrotik-api-ros6. Provides ServiceProvider, Facade, and config.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mivodev/laravel-mikrotik-api-ros6",
    "support": {
        "issues": "https://github.com/mivodev/laravel-mikrotik-api-ros6/issues",
        "source": "https://github.com/mivodev/laravel-mikrotik-api-ros6"
    },
    "keywords": [
        "laravel",
        "mikrotik",
        "routeros",
        "api",
        "ros6",
        "socket"
    ],
    "authors": [
        {
            "name": "Mivodev",
            "email": "mivo@dev.dyzulk.com",
            "homepage": "https://github.com/mivodev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "mivodev/mikrotik-api-ros6": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Mivo\\LaravelMikrotikRos6\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mivo\\LaravelMikrotikRos6\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mivo\\LaravelMikrotikRos6\\MikrotikRos6ServiceProvider"
            ],
            "aliases": {
                "MikrotikRos6": "Mivo\\LaravelMikrotikRos6\\Facades\\MikrotikRos6"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
